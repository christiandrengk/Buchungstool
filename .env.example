# SQLite (Standard für den lokalen Start)
DATABASE_URL="file:./dev.db"

# Optional: erlaubte Eltern-Domain für spätere iframe-Einbettung
# (z. B. https://www.uni-institut.example). Leer lassen = nur 'self'.
# ALLOWED_FRAME_ANCESTOR="https://www.uni-institut.example"

